# Groq API 키를 넣으면 규칙 엔진 대신 Groq(LLM)가 정의서+와이어프레임을 생성합니다.
# 발급: https://console.groq.com  (무료 티어 제공)
# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
GROQ_API_KEY=

# (선택) 모델 오버라이드
# HTML 생성용(고품질, 텍스트 전용). 기본값: openai/gpt-oss-120b
# GROQ_HTML_MODEL=openai/gpt-oss-120b
# 설계 판단·이미지 분석용(비전). 기본값: meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
